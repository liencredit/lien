# LIEN /api environment.
# Copy to .env and fill in. Never commit .env.

# Which Solana cluster to read 8004 from (devnet | mainnet).
LIEN_CLUSTER=mainnet

# 8004 indexer GraphQL endpoints (verified live 2026-06).
# Defaults are derived from LIEN_CLUSTER if these are unset.
EIGHT004_GRAPHQL_DEVNET=https://8004-indexer-dev.qnt.sh/v2/graphql
EIGHT004_GRAPHQL_MAINNET=https://8004-indexer-main.qnt.sh/v2/graphql

# HTTP server.
PORT=8787
HOST=0.0.0.0

# Load synthetic demo agents into the store on boot (true/false). Default true.
LIEN_SEED=true

# If set, write endpoints (POST /settlements, POST /attest) require
# `Authorization: Bearer <key>`. Reads stay public. Leave unset for open dev.
# LIEN_API_KEY=sk_live_xxx

# Max requests per IP per minute (0 disables). Default 120.
# LIEN_RATE_LIMIT=120

# On boot, score the top-N real 8004 agents into the store so /registry is
# populated without any external DB. 0 disables. Good value in prod: 20.
# LIEN_SEED_REAL=20

# Webhooks. Either a single endpoint:
# LIEN_WEBHOOK_URL=https://your-app.example/webhooks/lien
# LIEN_WEBHOOK_SECRET=whsec_xxx
# ...or multiple as JSON: LIEN_WEBHOOKS=[{"url":"...","secret":"..."}]

# Supabase storage. When both are set, the Store is Supabase-backed (apply
# ../db/schema.sql first); otherwise the API uses in-memory storage.
# The project URL is the same one your Lovable frontend uses; the service-role
# key comes from Supabase dashboard → Project Settings → API (NOT the anon key).
# SUPABASE_URL=https://<project-ref>.supabase.co
# SUPABASE_SERVICE_KEY=<service_role_key>
# When pointing at a real Supabase you usually want LIEN_SEED=false.

# Attestation / write-back (step 7). When both are set, the real AttestationWriter
# posts the score back on-chain / to 8004; otherwise a noop writer is used.
# LIEN_SIGNER_SECRET=        # base58 secret key of the LIEN authority signer
# LIEN_SCORE_PROGRAM_ID=     # deployed /program id (after `anchor deploy`)
